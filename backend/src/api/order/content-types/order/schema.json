{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderId": {
      "type": "string",
      "unique": true
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "S-01 Submetido",
        "S-02 Em Análise",
        "S-03 Info Adicional Solicitada",
        "S-04 Rejeitado",
        "S-05 Aprovado",
        "S-06 Aguardando Aceitação",
        "S-07 Aceite pelo Estafeta",
        "S-08 Em Recolha",
        "S-09 Em Trânsito",
        "S-10 No Destino",
        "S-11 Entregue",
        "S-12 Não Foi Possível Entregar",
        "S-13 Cancelado pelo Cliente",
        "S-14 Cancelado pelo Admin",
        "S-15 Concluído e Avaliado",
        "S-16 Concluído Sem Avaliação"
      ]
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "orders"
    },
    "total_price": {
      "type": "decimal"
    },
    "store_name": {
      "type": "string"
    },
    "items": {
      "type": "json"
    },
    "is_urgent": {
      "type": "boolean"
    },
    "courier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::courier-estafeta.courier-estafeta",
      "inversedBy": "orders"
    },
    "delivery": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::delivery.delivery",
      "mappedBy": "order"
    },
    "review": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::review.review",
      "mappedBy": "order"
    },
    "priority": {
      "type": "integer",
      "min": 1,
      "max": 5
    },
    "estimatedTime": {
      "type": "integer"
    },
    "deliveryAddress": {
      "type": "string"
    },
    "deliveryLatitude": {
      "type": "decimal"
    },
    "deliveryLongitude": {
      "type": "decimal"
    },
    "storeLatitude": {
      "type": "decimal"
    },
    "storeLongitude": {
      "type": "decimal"
    },
    "rejectionReason": {
      "type": "string"
    },
    "cancelReason": {
      "type": "string"
    },
    "go_points_used": {
      "type": "integer",
      "default": 0
    },
    "go_points_redemption": {
      "type": "string"
    },
    "adminMessage": {
      "type": "text"
    },
    "clientReply": {
      "type": "text"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5
    },
    "chatHistory": {
      "type": "json"
    },
    "notes": {
      "type": "text"
    },
    "invoiceEmailSent": {
      "type": "boolean",
      "default": false
    }
  }
}
